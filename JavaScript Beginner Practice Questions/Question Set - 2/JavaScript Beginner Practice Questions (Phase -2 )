    </div>

    <div class="qa">
      <div class="question">25. Closure counter function.</div>
      <pre><code>function counter() {
  let count = 0;

  return function() {
    count++;
    return count;
  };
}

const c = counter();
console.log(c());
console.log(c());</code></pre>
    </div>

    <div class="qa">
      <div class="question">26. Currying example.</div>
      <pre><code>function add(a) {
  return function(b) {
    return a + b;
  };
}

console.log(add(5)(10));</code></pre>
    </div>

    <div class="qa">
      <div class="question">27. Debounce function logic.</div>
      <pre><code>function debounce(fn, delay) {
  let timer;

  return function() {
    clearTimeout(timer);
    timer = setTimeout(() => fn(), delay);
  };
}</code></pre>
    </div>

    <div class="qa">
      <div class="question">28. Throttle function logic.</div>
      <pre><code>function throttle(fn, delay) {
  let lastCall = 0;

  return function() {
    let now = Date.now();

    if (now - lastCall >= delay) {
      lastCall = now;
      fn();
    }
  };
}</code></pre>
    </div>

    <div class="qa">
      <div class="question">29. Function that executes only once.</div>
      <pre><code>function once(fn) {
  let called = false;

  return function() {
    if (!called) {
      called = true;
      fn();
    }
  };
}</code></pre>
    </div>

    <div class="qa">
      <div class="question">30. Custom implementation of map.</div>
      <pre><code>function customMap(arr, callback) {
  let result = [];

  for (let i = 0; i < arr.length; i++) {
    result.push(callback(arr[i]));
  }

  return result;
}

console.log(customMap([1,2,3], x => x * 2));</code></pre>
    </div>

    <div class="qa">
      <div class="question">31. Custom implementation of filter.</div>
      <pre><code>function customFilter(arr, callback) {
  let result = [];

  for (let item of arr) {
    if (callback(item)) {
      result.push(item);
    }
  }

  return result;
}</code></pre>
    </div>

    <div class="qa">
      <div class="question">32. Custom implementation of reduce.</div>
      <pre><code>function customReduce(arr, callback, initial) {
  let accumulator = initial;

  for (let item of arr) {
    accumulator = callback(accumulator, item);
  }

  return accumulator;
}</code></pre>
    </div>

    <div class="qa">
      <div class="question">33. Custom forEach.</div>
      <pre><code>function customForEach(arr, callback) {
  for (let i = 0; i < arr.length; i++) {
    callback(arr[i], i);
  }
}</code></pre>
    </div>

